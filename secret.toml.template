[asr]
# 语音识别 API Key
API_KEY = "your_asr_api_key_here"

[llm]
# 大语言模型 API Key
API_KEY = "your_llm_api_key_here"

# 使用说明：
# 1. 复制此文件为 secret.toml
# 2. 将 your_asr_api_key_here 替换为你的语音识别 API Key
# 3. 将 your_llm_api_key_here 替换为你的大语言模型 API Key
# 4. 可以使用相同的 API Key，也可以使用不同的
# 5. 在阿里云控制台获取 API Key: https://dashscope.console.aliyun.com/
